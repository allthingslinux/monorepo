# ObsidianIRC — Modern IRC web client

set positional-arguments := true

compose := "docker compose -f ../../../compose.yaml"

default:
    @just --list

shell:
    {{ compose }} exec atl-irc-client-obsidian sh
logs:
    {{ compose }} logs -f atl-irc-client-obsidian
build:
    {{ compose }} build atl-irc-client-obsidian
build-clean:
    {{ compose }} build --no-cache atl-irc-client-obsidian
