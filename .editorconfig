# EditorConfig for atl.chat Monorepo
# https://editorconfig.org
root = true

# === Global Defaults ===
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# === Languages ===

# Python
[*.py]
indent_style = space
indent_size = 4

# JavaScript / TypeScript / Web
[*.{js,jsx,ts,tsx,cjs,mjs}]
indent_style = space
indent_size = 2

# JSON / YAML / Configs
[*.{json,yaml,yml,toml,conf,ini}]
indent_style = space
indent_size = 2

# Markdown — trailing whitespace is meaningful (line breaks)
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Lua (Prosody / XMPP) — Prosody convention is tabs
[*.lua]
indent_style = tab
tab_width = 4

# Docker
[{Dockerfile,Containerfile}*]
indent_style = space
indent_size = 4

# Makefiles — must use tabs
[Makefile]
indent_style = tab
tab_width = 4

# Go — gofmt uses tabs
[*.go]
indent_style = tab
tab_width = 4

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
