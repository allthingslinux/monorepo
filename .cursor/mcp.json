{
  "mcpServers": {
    "llms.txt": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "shadcn:https://ui.shadcn.com/llms.txt",
        "drizzle:https://orm.drizzle.team/llms.txt",
        "better-auth:https://www.better-auth.com/llms.txt",
        "better-auth-ui:https://better-auth-ui.com/llms.txt",
        "--transport",
        "stdio"
      ],
      "type": "stdio"
    },
    "shadcn-web": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "cwd": "apps/web"
    },
    "shadcn-portal": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "cwd": "apps/portal"
    },
    "betterauth": {
      "url": "https://mcp.chonkie.ai/better-auth/better-auth-builder/mcp",
      "headers": {},
      "type": "remote"
    },
    "ultracite": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://www.ultracite.ai/api/mcp/mcp"],
      "type": "stdio"
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
      "type": "stdio"
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp/allthingslinux/portal",
      "type": "remote"
    }
  }
}
