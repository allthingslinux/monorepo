{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/out/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/*.min.js",
    "**/next-env.d.ts",
    "**/cloudflare-env.d.ts",
    "**/worker-configuration.d.ts",
    "apps/web/.contentlayer/**",
    "apps/web/.open-next/**",
    "apps/web/.wrangler/**",
    "apps/portal/references/**",
    "apps/portal/drizzle/**",
    "apps/portal/.cursor/skills/**"
  ],
  "extends": [
    "./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/react/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/next/.oxlintrc.json"
  ],
  "rules": {
    "import/no-namespace": "error",
    "oxc/no-barrel-file": "error",
    "func-style": "off",
    "global-require": "off",
    "unicorn/prefer-module": "off",
    "no-inline-comments": "off",
    "react_perf/jsx-no-new-function-as-prop": "off",
    "prefer-destructuring": "off",
    "no-use-before-define": "off",
    "typescript/no-explicit-any": "off",
    "promise/prefer-await-to-callbacks": "off",
    "no-shadow": "off",
    "no-warning-comments": "off",
    "unicorn/prefer-dom-node-remove": "off",
    "unicorn/prefer-string-replace-all": "off",
    "typescript/consistent-type-imports": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/text-encoding-identifier-case": "off",
    "unicorn/no-immediate-mutation": "off",
    "jsdoc/check-tag-names": "off",
    "typescript/parameter-properties": "off",
    "typescript/no-non-null-assertion": "off",
    "unicorn/prefer-array-find": "off",
    "unicorn/prefer-ternary": "off",
    "unicorn/prefer-spread": "off",
    "unicorn/prefer-regexp-test": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/no-array-for-each": "off",
    "react/no-danger": "off",
    "max-classes-per-file": "off",
    "complexity": "off"
  },
  "overrides": [
    {
      "files": [
        "apps/portal/src/shared/schemas/index.ts",
        "apps/portal/src/shared/schemas/integrations/index.ts",
        "apps/portal/src/features/integrations/api/index.ts",
        "apps/portal/src/features/user/api/index.ts",
        "apps/portal/src/features/admin/api/index.ts",
        "apps/portal/src/shared/api/index.ts",
        "apps/portal/src/shared/types/api.ts",
        "apps/portal/src/app/metadata.ts",
        "apps/portal/src/features/integrations/lib/xmpp/index.ts"
      ],
      "rules": {
        "oxc/no-barrel-file": "off"
      }
    },
    {
      "files": [
        "apps/portal/src/features/routing/lib/index.ts",
        "apps/portal/src/features/auth/lib/index.ts",
        "apps/portal/src/features/integrations/lib/mailcow/index.ts",
        "apps/portal/src/features/integrations/lib/mediawiki/index.ts",
        "apps/portal/src/features/integrations/lib/irc/index.ts",
        "apps/portal/src/features/integrations/lib/xmpp/index.ts",
        "apps/portal/src/hooks/index.ts",
        "apps/portal/src/components/layout/page/index.ts",
        "apps/portal/src/components/layout/sidebar/index.ts",
        "apps/portal/src/components/layout/index.ts",
        "apps/portal/src/components/layout/header/index.ts",
        "apps/portal/src/components/layout/navigation/index.ts",
        "apps/portal/src/shared/config/index.ts"
      ],
      "rules": {
        "oxc/no-barrel-file": "off"
      }
    },
    {
      "files": [
        "apps/portal/src/features/**/implementation.ts",
        "apps/portal/src/features/**/lib/config.ts",
        "apps/portal/src/features/**/client.ts",
        "apps/portal/src/features/**/unreal/client.ts",
        "apps/portal/src/features/**/components/*.tsx",
        "apps/portal/src/app/**/integrations-content.tsx",
        "apps/portal/src/sentry.*.ts"
      ],
      "rules": {
        "import/no-namespace": "off"
      }
    },
    {
      "files": ["apps/web/**/*.{ts,tsx}"],
      "rules": {
        "unicorn/filename-case": "off",
        "react/jsx-handler-names": "off"
      }
    },
    {
      "files": ["apps/web/src/components/mdx-components.tsx"],
      "rules": {
        "import/no-namespace": "off",
        "jsx-a11y/anchor-has-content": "off",
        "jsx-a11y/heading-has-content": "off",
        "react/no-react-children": "off",
        "no-nested-ternary": "off",
        "unicorn/no-nested-ternary": "off"
      }
    },
    {
      "files": ["apps/web/scripts/**/*.mjs"],
      "rules": {
        "import/no-namespace": "off",
        "no-param-reassign": "off"
      }
    },
    {
      "files": ["apps/portal/src/features/auth/lib/localization.ts"],
      "rules": {
        "sort-keys": "off"
      }
    },
    {
      "files": [
        "apps/portal/src/features/integrations/lib/**/implementation.ts"
      ],
      "rules": {
        "class-methods-use-this": "off"
      }
    },
    {
      "files": ["packages/ui/**/*.{ts,tsx}"],
      "rules": {
        "import/no-namespace": "off",
        "jsx-a11y/label-has-associated-control": "off",
        "unicorn/no-document-cookie": "off",
        "react/button-has-type": "off",
        "no-nested-ternary": "off",
        "unicorn/no-nested-ternary": "off",
        "jsx-a11y/prefer-tag-over-role": "off",
        "jsx-a11y/click-events-have-key-events": "off",
        "react/jsx-no-constructed-context-values": "off",
        "react/no-clone-element": "off",
        "react/no-react-children": "off",
        "no-negated-condition": "off",
        "jsx-a11y/anchor-has-content": "off"
      }
    }
  ]
}