{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/react/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/next/.oxlintrc.json"
  ],
  "rules": {
    "import/no-namespace": "error",
    "oxc/no-barrel-file": "error",
    "func-style": "off",
    "sort-keys": "off",
    "global-require": "off",
    "unicorn/prefer-module": "off",
    "no-inline-comments": "off",
    "react_perf/jsx-no-new-function-as-prop": "off",
    "prefer-destructuring": "off",
    "no-use-before-define": "off",
    "class-methods-use-this": "off",
    "typescript/no-explicit-any": "off",
    "promise/prefer-await-to-callbacks": "off",
    "import/first": "off",
    "promise/prefer-await-to-then": "off",
    "import/no-named-as-default-member": "off",
    "require-await": "off",
    "no-eq-null": "off",
    "eqeqeq": "off",
    "no-shadow": "off",
    "no-warning-comments": "off",
    "no-empty-function": "off",
    "unicorn/prefer-dom-node-remove": "off",
    "no-plusplus": "off",
    "unicorn/prefer-string-replace-all": "off",
    "typescript/consistent-type-imports": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/text-encoding-identifier-case": "off",
    "unicorn/no-immediate-mutation": "off",
    "jsdoc/check-tag-names": "off",
    "typescript/parameter-properties": "off",
    "typescript/no-non-null-assertion": "off",
    "unicorn/prefer-array-find": "off",
    "unicorn/prefer-ternary": "off",
    "unicorn/prefer-spread": "off",
    "unicorn/prefer-regexp-test": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/no-empty-file": "off",
    "unicorn/no-array-for-each": "off",
    "react/no-danger": "off",
    "no-useless-return": "off",
    "max-classes-per-file": "off",
    "complexity": "off",
    "arrow-body-style": "off",
    "react/no-array-index-key": "off"
  },
  "overrides": [
    {
      "files": [
        "apps/portal/apps/portal/src/shared/schemas/index.ts",
        "apps/portal/apps/portal/src/shared/schemas/integrations/index.ts",
        "apps/portal/apps/portal/src/features/integrations/api/index.ts",
        "apps/portal/apps/portal/src/features/user/api/index.ts",
        "apps/portal/apps/portal/src/features/admin/api/index.ts",
        "apps/portal/apps/portal/src/shared/api/index.ts",
        "apps/portal/apps/portal/src/shared/types/api.ts",
        "apps/portal/apps/portal/src/app/metadata.ts",
        "apps/portal/apps/portal/src/features/integrations/lib/xmpp/index.ts"
      ],
      "rules": {
        "oxc/no-barrel-file": "off"
      }
    },
    {
      "files": ["apps/portal/packages/ui/src/layout/index.ts"],
      "rules": {
        "oxc/no-barrel-file": "off"
      }
    },
    {
      "files": [
        "apps/portal/apps/portal/src/features/**/implementation.ts",
        "apps/portal/apps/portal/src/features/**/lib/config.ts",
        "apps/portal/apps/portal/src/features/**/client.ts",
        "apps/portal/apps/portal/src/features/**/unreal/client.ts",
        "apps/portal/apps/portal/src/features/**/components/*.tsx",
        "apps/portal/apps/portal/src/app/**/integrations-content.tsx",
        "apps/portal/apps/portal/src/sentry.*.ts"
      ],
      "rules": {
        "import/no-namespace": "off"
      }
    }
  ]
}