# apps/obsidianirc/Containerfile
# Builds ObsidianIRC from the upstream submodule with ATL-specific build args.
# VITE_HIDE_SERVER_LIST=true removes the Discover page and multi-server UI.
# VITE_DEFAULT_IRC_SERVER auto-connects to the ATL IRC WebSocket.

FROM node:23-alpine AS builder

ARG VITE_DEFAULT_IRC_SERVER
ARG VITE_DEFAULT_IRC_SERVER_NAME
ARG VITE_DEFAULT_IRC_CHANNELS
ARG VITE_HIDE_SERVER_LIST=true

ENV VITE_DEFAULT_IRC_SERVER=$VITE_DEFAULT_IRC_SERVER
ENV VITE_DEFAULT_IRC_SERVER_NAME=$VITE_DEFAULT_IRC_SERVER_NAME
ENV VITE_DEFAULT_IRC_CHANNELS=$VITE_DEFAULT_IRC_CHANNELS
ENV VITE_HIDE_SERVER_LIST=$VITE_HIDE_SERVER_LIST

WORKDIR /app
COPY upstream/package*.json ./
RUN npm ci
COPY upstream/ .
# Inline build args in RUN so Docker invalidates cache when they change
# (RUN cache uses command string, not ENV; without this, cached layers can serve stale config)
RUN VITE_DEFAULT_IRC_SERVER="$VITE_DEFAULT_IRC_SERVER" \
    VITE_DEFAULT_IRC_SERVER_NAME="$VITE_DEFAULT_IRC_SERVER_NAME" \
    VITE_DEFAULT_IRC_CHANNELS="$VITE_DEFAULT_IRC_CHANNELS" \
    VITE_HIDE_SERVER_LIST="$VITE_HIDE_SERVER_LIST" \
    npm run build

FROM nginx:alpine

LABEL maintainer="All Things Linux IRC Infrastructure" \
    description="ObsidianIRC - Modern IRC web client" \
    org.opencontainers.image.source="https://github.com/allthingslinux/atl.chat"

COPY upstream/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1
