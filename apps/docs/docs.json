{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "All Things Linux",
  "description": "All Things Linux is a 501(c)(3) non-profit organization with a mission to empower the Linux ecosystem through education, collaboration, and support.",
  "colors": {
    "primary": "#64748b",
    "light": "#94a3b8",
    "dark": "#475569"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:type": "website",
      "og:site_name": "All Things Linux",
      "twitter:card": "summary_large_image"
    }
  },
  "search": {
    "prompt": "Enter a search term…"
  },
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "spec": {
      "download": true
    }
  },
  "navigation": {
    "dropdowns": [
      {
        "dropdown": "Overview",
        "icon": "layout-grid",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "about",
              "quickstart",
              "development",
              "contributing"
            ]
          }
        ]
      },
      {
        "dropdown": "portal",
        "icon": "user",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["portal/index"]
          }
        ]
      },
      {
        "dropdown": "atl.chat",
        "icon": "messages-square",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["chat/index"]
          }
        ]
      },
      {
        "dropdown": "atl.sh",
        "icon": "terminal",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["sh/index"]
          }
        ]
      },
      {
        "dropdown": "atl.dev",
        "icon": "cloud",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["dev/index"]
          }
        ]
      },
      {
        "dropdown": "atl.tools",
        "icon": "server",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["tools/index"]
          }
        ]
      },
      {
        "dropdown": "atl.wiki",
        "icon": "book-marked",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["wiki/index"]
          }
        ]
      },
      {
        "dropdown": "tux",
        "icon": "bot",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["tux/index"]
          }
        ]
      },
      {
        "dropdown": "Authoring",
        "icon": "pen-line",
        "groups": [
          {
            "group": "Site configuration",
            "pages": ["essentials/settings", "essentials/navigation"]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "dropdown": "API reference",
        "icon": "braces",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://allthingslinux.org",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/allthingslinux",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/linux",
          "icon": "discord"
        },
        {
          "anchor": "Open Collective",
          "href": "https://opencollective.com/allthingslinux",
          "icon": "heart"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Organization",
        "href": "https://github.com/allthingslinux"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Mintlify dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp", "cursor"]
  }
}