{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "All Things Linux",
  "description": "Product and platform documentation for All Things Linux: portal, atl.chat, atl.sh, atl.dev, atl.tools, atl.wiki, tux, plus Mintlify authoring guides. 501(c)(3) Linux community.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:type": "website",
      "og:site_name": "All Things Linux",
      "twitter:card": "summary_large_image"
    }
  },
  "search": {
    "prompt": "Search All Things Linux docs…"
  },
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "spec": {
      "download": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "about",
              "quickstart",
              "development",
              "contributing"
            ]
          }
        ]
      },
      {
        "tab": "portal",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/portal/index"]
          }
        ]
      },
      {
        "tab": "atl.chat",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/atl-chat/index"]
          }
        ]
      },
      {
        "tab": "atl.sh",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/atl-sh/index"]
          }
        ]
      },
      {
        "tab": "atl.dev",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/atl-dev/index"]
          }
        ]
      },
      {
        "tab": "atl.tools",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/atl-tools/index"]
          }
        ]
      },
      {
        "tab": "atl.wiki",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/atl-wiki/index"]
          }
        ]
      },
      {
        "tab": "tux",
        "groups": [
          {
            "group": "Documentation",
            "pages": ["products/tux/index"]
          }
        ]
      },
      {
        "tab": "Authoring",
        "groups": [
          {
            "group": "Site configuration",
            "pages": ["essentials/settings", "essentials/navigation"]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/allthingslinux",
          "icon": "github"
        },
        {
          "anchor": "Mintlify docs",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Organization",
        "href": "https://github.com/allthingslinux"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Mintlify dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp", "cursor"]
  }
}