{
  "extends": "@portal/typescript-config/library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/auth": ["../../src/features/auth/lib"],
      "@/auth/*": ["../../src/features/auth/lib/*"],
      "@/config": ["../../src/shared/config"],
      "@/config/*": ["../../src/shared/config/*"],
      "@/*": ["../../src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}