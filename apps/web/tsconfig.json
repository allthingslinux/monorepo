{
  "extends": "@atl/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "contentlayer/generated": ["./.contentlayer/generated"]
    },
    "types": ["node", "@cloudflare/workers-types", "./types/env.d.ts"],
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mjs",
    "**/*.cjs",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".contentlayer/generated",
    "src/types/**/*.d.ts",
    "trigger.config.ts"
  ],
  "exclude": ["node_modules", "open-next.config.ts"]
}
