{
  "name": "@atl/web",
  "version": "0.1.0",
  "private": true,
  "exports": {
    "./alchemy": "./alchemy.run.ts"
  },
  "scripts": {
    "transit": "true",
    "clean": "rm -rf .next .turbo .open-next",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "trigger": "npx trigger.dev@latest dev",
    "build": "next build",
    "deploy": "pnpm exec alchemy deploy --app web",
    "destroy": "pnpm exec alchemy destroy --app web",
    "secrets:dev": "bash ../../.github/scripts/web/secrets.sh dev",
    "secrets:prod": "bash ../../.github/scripts/web/secrets.sh prod",
    "setup:bindings": "bash scripts/setup-bindings.sh",
    "check": "pnpm run type-check && pnpm exec ultracite check",
    "fix": "pnpm exec ultracite fix",
    "test": "vitest",
    "type-check": "pnpm exec contentlayer2 build && tsc --noEmit",
    "analyze:bundle": "echo 'After building, check .open-next/server-functions/default/handler.mjs.meta.json with https://esbuild.github.io/analyze/'",
    "coc:generate": "node scripts/generate-code-of-conduct.mjs",
    "shadcn:add": "shadcn add"
  },
  "dependencies": {
    "@atl/ui": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mondaydotcomorg/api": "^14.0.0",
    "@next/mdx": "^16.2.1",
    "@next/third-parties": "^16.2.1",
    "@react-three/fiber": "^9.5.0",
    "@stepperize/react": "^5.1.9",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.40.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@trigger.dev/sdk": "latest",
    "alchemy": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "date-fns": "^4.1.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "feed": "^5.2.0",
    "globals": "^17.4.0",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.5",
    "next": "16.2.1",
    "next-contentlayer2": "^0.5.8",
    "node-quickbooks": "^2.0.48",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "trigger.dev": "^4.4.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@opennextjs/cloudflare": "^1.17.3",
    "@svgr/webpack": "^8.1.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/webpack": "^5.28.5",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv": "^17.3.1",
    "open": "^11.0.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}
