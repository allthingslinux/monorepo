    "@tabler/icons-react": "^3.40.0",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "^0.5.19",
    "@trigger.dev/sdk": "latest",
    "alchemy": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "contentlayer2": "^0.5.8",
    "date-fns": "catalog:",
    "embla-carousel-auto-scroll": "catalog:",
    "embla-carousel-react": "catalog:",
