{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "SENTRY_*",
        "GIT_COMMIT_SHA"
      ]
    },

    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },

    "type-check": {
      "dependsOn": ["^transit"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },

    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [],
      "env": ["DATABASE_URL", "FIBERY_ACCOUNT", "FIBERY_TOKEN"]
    },

    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL", "FIBERY_ACCOUNT", "FIBERY_TOKEN"]
    },

    "transit": { "dependsOn": ["^transit"] },
    "clean": { "cache": false },

    "//#check": {},
    "//#fix": { "cache": false },

    "db:generate": {
      "inputs": ["../../packages/db/src/schema/**", "src/schema/**"],
      "outputs": ["drizzle/**"],
      "cache": false
    },
    "db:migrate": { "cache": false },
    "db:push": { "cache": false },

    "deploy": { "dependsOn": ["^deploy"], "cache": false },
    "destroy": { "dependsOn": ["^destroy"], "cache": false },

    "docker:build": {
      "dependsOn": ["^build"],
      "inputs": ["Containerfile", "src/**", ".containerignore"],
      "outputs": [],
      "cache": false
    },

    "docker:push": {
      "dependsOn": ["docker:build"],
      "cache": false
    },

    "//#py:check": { "cache": false },
    "//#py:test": { "cache": false },
    "//#py:test:bridge": { "cache": false }
  },

  "globalDependencies": ["pnpm-lock.yaml"],
  "globalEnv": ["NODE_ENV", "CI"]
}
