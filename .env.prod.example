# =============================================================================
# allthingslinux monorepo — production overrides (.env.prod.example)
# Copy to .env.prod. Overrides .env for `just chat-prod`.
# =============================================================================

ATL_CHAT_IP=0.0.0.0
ATL_GATEWAY_IP=172.20.0.1

IRC_DOMAIN=irc.atl.chat
IRC_ROOT_DOMAIN=atl.chat
XMPP_DOMAIN=xmpp.atl.chat
PROSODY_DOMAIN=xmpp.atl.chat

IRC_SSL_CERT_PATH=/home/unrealircd/unrealircd/certs/live/irc.atl.chat/fullchain.pem
IRC_SSL_KEY_PATH=/home/unrealircd/unrealircd/certs/live/irc.atl.chat/privkey.pem
PROSODY_SSL_KEY=/etc/prosody/certs/live/xmpp.atl.chat/privkey.pem
PROSODY_SSL_CERT=/etc/prosody/certs/live/xmpp.atl.chat/fullchain.pem

IRC_TLS_VERIFY=true
IRC_LOUNGE_REJECT_UNAUTHORIZED=true
IRC_WEBSOCKET_USE_TLS=false
BRIDGE_IRC_TLS_VERIFY=true

PROSODY_ALLOW_PLACEHOLDER_KEY=false
PROSODY_HTTPS_VIA_PROXY=true
PROSODY_UPLOAD_EXTERNAL_URL=https://xmpp.atl.chat/upload/
PROSODY_HTTP_EXTERNAL_URL=https://xmpp.atl.chat/
PROSODY_PROXY_ADDRESS=xmpp.atl.chat

PROSODY_C2S_REQUIRE_ENCRYPTION=true
PROSODY_S2S_REQUIRE_ENCRYPTION=true
PROSODY_S2S_SECURE_AUTH=true
PROSODY_ALLOW_UNENCRYPTED_PLAIN_AUTH=false

BRIDGE_PORTAL_BASE_URL=https://portal.atl.chat
BRIDGE_PORTAL_TOKEN=
BRIDGE_XMPP_COMPONENT_JID=bridge.xmpp.atl.chat
BRIDGE_RELAYMSG_CLEAN_NICKS=true
LOG_LEVEL=INFO

XMPP_AVATAR_PUBLIC_URL=https://xmpp.atl.chat
XMPP_UPLOAD_FETCH_URL=https://xmpp.atl.chat

NEXT_PUBLIC_IRC_WS_URL=wss://irc.atl.chat/ws
NEXT_PUBLIC_XMPP_BOSH_URL=https://xmpp.atl.chat/http-bind
