{
  "name": "@atl/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "transit": "true",
    "clean": "true",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@atl/db": "workspace:*",
    "@atl/schemas": "workspace:*",
    "@atl/types": "workspace:*",
    "@atl/utils": "workspace:*",
    "@better-auth/api-key": "catalog:auth",
    "@better-auth/oauth-provider": "catalog:auth",
    "@better-auth/passkey": "catalog:auth",
    "@daveyplate/better-auth-tanstack": "catalog:auth",
    "@sentry/nextjs": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "better-auth": "catalog:auth",
    "drizzle-orm": "catalog:",
    "next": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "server-only": "catalog:",
    "sonner": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "typescript": "catalog:"
  }
}
