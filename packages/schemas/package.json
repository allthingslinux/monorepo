{
  "name": "@atl/schemas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./integrations/*": {
      "types": "./src/integrations/*.ts",
      "default": "./src/integrations/*.ts"
    }
  },
  "scripts": {
    "transit": "true",
    "clean": "true",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@atl/db": "workspace:*",
    "@atl/types": "workspace:*",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
