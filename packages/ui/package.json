{
  "name": "@atl/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./styles/design-tokens.css": "./src/styles/design-tokens.css",
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    }
  },
  "scripts": {
    "clean": "true",
    "transit": "true",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "date-fns": "catalog:",
    "embla-carousel-auto-scroll": "catalog:",
    "embla-carousel-react": "catalog:",
    "input-otp": "catalog:",
    "lucide-react": "catalog:",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "catalog:",
    "recharts": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "vaul": "catalog:"
  },
  "devDependencies": {
    "@atl/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next-themes": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:"
  },
  "peerDependenciesMeta": {
    "next-themes": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  }
}
