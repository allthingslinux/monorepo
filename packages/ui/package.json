{
  "name": "@atl/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./styles/design-tokens.css": "./src/styles/design-tokens.css",
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    }
  },
  "scripts": {
    "transit": "true",
    "clean": "true",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "date-fns": "catalog:",
    "embla-carousel-auto-scroll": "catalog:",
    "embla-carousel-react": "catalog:",
    "input-otp": "^1.4.2",
    "lucide-react": "catalog:",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.7.5",
    "recharts": "3.8.0",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next-themes": "^0.4.6",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": "catalog:",
    "next-themes": "^0.4.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "next-themes": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  }
}
