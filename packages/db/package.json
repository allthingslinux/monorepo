{
  "name": "@atl/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "types": "./src/schema/*.ts",
      "default": "./src/schema/*.ts"
    }
  },
  "scripts": {
    "transit": "true",
    "clean": "true",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config src/config.ts",
    "db:migrate": "drizzle-kit migrate --config src/config.ts",
    "db:push": "drizzle-kit push --config src/config.ts",
    "db:studio": "drizzle-kit studio --config src/config.ts"
  },
  "dependencies": {
    "@atl/types": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "server-only": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
