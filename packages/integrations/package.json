{
  "name": "@atl/integrations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "clean": "true",
    "transit": "true",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "catalog:",
    "graphql": "catalog:",
    "graphql-request": "catalog:",
    "node-quickbooks": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@atl/tsconfig": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
