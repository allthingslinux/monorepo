{
  "name": "atl-tools",
  "version": "1.0.0",
  "scripts": {
    "build": "tailwindcss -i src/input.css -o src/output.css --watch",
    "build:prod": "tailwindcss -i src/input.css -o src/output.css --minify",
    "dev": "wrangler pages dev src --compatibility-date=2025-08-09",
    "deploy": "npm run build:prod && wrangler pages deploy src",
    "preview": "wrangler pages dev src"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@iconify/json": "^2.2.367",
    "tailwindcss": "^4.1.11",
    "wrangler": "^4.28.1"
  }
}
