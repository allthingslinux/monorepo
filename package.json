{
  "name": "allthingslinux-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean --continue || true",
    "py:check": "uv run ruff check apps/bridge/src apps/bridge/tests && uv run ruff format --check apps/bridge/src apps/bridge/tests",
    "py:test": "uv run pytest apps/bridge/tests -v --tb=short"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "zod": "4.3.6"
    }
  }
}