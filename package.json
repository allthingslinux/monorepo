{
  "name": "atl-tools",
  "version": "1.0.0",
  "scripts": {
    "build": "npx @tailwindcss/cli@next -i src/input.css -o src/output.css --watch",
    "build:prod": "npx @tailwindcss/cli@next -i src/input.css -o src/output.css --minify",
    "build:dist": "npm run copy:files",
    "copy:files": "rm -rf dist && mkdir -p dist && cp -r src dist/ && cp -r assets dist/",
    "dev": "npm run build:dist && wrangler dev",
    "deploy": "npm run build:dist && wrangler deploy",
    "preview": "npm run build:dist && wrangler dev"
  },

  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@iconify/json": "^2.2.367",
    "tailwindcss": "^4.1.11",
    "wrangler": "^4.28.1"
  }
}
