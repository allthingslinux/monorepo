.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm
.pnpm-store

# Testing
coverage/

# Next.js
.next/
out/

# Turborepo
.turbo/

# Production
build/

# Contentlayer (web)
.contentlayer/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env (keep examples committed; ignore local secrets)
.env
.env*.local
.env.secrets
.env.secrets.dev
.env.secrets.prod
.env.dev
.env.prod

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OpenNext / Cloudflare (web)
.open-next/
.dev.vars
.wrangler/

# Alchemy (IaC / deploy state — use remote CloudflareStateStore in CI)
.alchemy/

# Trigger.dev
.trigger/

# Portal: reference & examples
references/
examples/

# IDE
.cursor/plans/
.cursor/hooks/logs/

# Misc project paths
form-backups/
# next-agents-md
.next-docs/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.uv_cache/
.hypothesis/
.pytest_cache/
.ruff_cache/

# Docker runtime data
data/

# Generated configs (Model A: envsubst writes inside container, not on host)
services/chat/irc-server/config/unrealircd.conf
services/chat/irc-services/config/atheme.conf
apps/bridge/config.yaml

# Fumadocs build artifacts (atl-chat docs — framework not used, content merged)
.source/

