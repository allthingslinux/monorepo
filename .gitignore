# Git — monorepo-wide (single root file; no per-app .gitignore).
# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm
.pnpm-store

# Testing
coverage/

# Next.js
.next/
out/

# Turborepo
.turbo/

# Production
build/

# Contentlayer (web)
.contentlayer/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env (keep examples committed; ignore local secrets)
.env
.env*.local
.env.secrets
.env.secrets.dev
.env.secrets.prod

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# OpenNext / Cloudflare (web)
.open-next/
.dev.vars
.wrangler/

# Alchemy (IaC / deploy state — use remote CloudflareStateStore in CI)
.alchemy/

# Trigger.dev
.trigger/

# Portal: reference & examples
references/
examples/

# IDE
.cursor/plans/
.cursor/hooks/logs/

# Misc project paths
form-backups/
# next-agents-md
.next-docs/
