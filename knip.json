{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{mjs,ts}"],
      "project": ["scripts/**/*.{mjs,ts}"],
      "ignoreDependencies": [
        "@commitlint/cli",
        "@commitlint/config-conventional",
        "@commitlint/types",
        "@intellectronica/ruler",
        "lefthook",
        "oxfmt",
        "oxlint",
        "oxlint-tsgolint",
        "sherif"
      ]
    },
    "apps/portal": {
      "ignoreDependencies": [
        "@semantic-release/changelog",
        "@semantic-release/exec",
        "@semantic-release/git",
        "semantic-release",
        "semantic-release-major-tag"
      ]
    },
    "apps/web": {
      "entry": ["contentlayer.config.ts"],
      "ignore": ["src/lib/integrations/**"]
    },
    "apps/docs": {
      "ignore": ["**/*"]
    }
  },
  "ignoreWorkspaces": ["packages/tsconfig"]
}
