{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{mjs,ts}"],
      "project": ["scripts/**/*.{mjs,ts}"]
    },
    "apps/web": {
      "entry": ["contentlayer.config.ts"],
      "ignore": ["src/lib/integrations/**"]
    },
    "apps/docs": {
      "ignore": ["**/*"]
    }
  },
  "ignoreWorkspaces": ["packages/tsconfig"],
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "optionalPeerDependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "unresolved": "warn",
    "exports": "warn",
    "types": "warn",
    "enumMembers": "warn",
    "duplicates": "off"
  }
}
